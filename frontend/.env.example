# SCAI NFT Marketplace — Frontend environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Pinata IPFS ───────────────────────────────────────────────────────────────
# Create a free account at https://app.pinata.cloud
# Then generate an API key: https://app.pinata.cloud/keys
VITE_PINATA_API_KEY=your_pinata_api_key_here
VITE_PINATA_SECRET=your_pinata_secret_api_key_here
