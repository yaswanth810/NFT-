# Environment Variables for NFT Marketplace on SCAI Network
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# Your wallet private key (with or without 0x prefix)
PRIVATE_KEY=

# SCAI Network RPC URL
SCAI_RPC_URL=https://mainnet-rpc.scai.network

# SCAI Block Explorer URL
SCAI_EXPLORER_URL=https://explorer.securechain.ai

# NOTE: SCAI Explorer does not issue API keys.
# No SCAI_EXPLORER_API_KEY entry is needed.

# Optional: Enable gas reporting in tests (set to "true" to enable)
REPORT_GAS=false
